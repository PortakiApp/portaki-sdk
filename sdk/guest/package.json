{
  "name": "@portaki/sdk",
  "version": "0.4.0",
  "description": "Portaki guest module bridge — React hooks, slots, HMAC bridge to Route Handlers",
  "license": "AGPL-3.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/PortakiApp/portaki-sdk",
    "directory": "sdk/guest"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19",
    "typescript": "^5"
  }
}
