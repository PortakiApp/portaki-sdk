{
  "name": "@portaki/sdk-test-support",
  "version": "2.0.0",
  "description": "Vitest + Testing Library harness for @portaki/module-* guest and host UIs",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/PortakiApp/portaki-sdk",
    "directory": "packages/sdk-test-support"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vitest": {
      "types": "./dist/vitest-preset.d.ts",
      "import": "./dist/vitest-preset.js"
    },
    "./vitest-setup": {
      "types": "./dist/vitest-setup.d.ts",
      "import": "./dist/vitest-setup.js"
    }
  },
  "files": ["dist", "schema"],
  "scripts": {
    "build": "node scripts/copy-schema.mjs && tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@portaki/sdk": "^2.0.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@portaki/sdk": "workspace:*",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@portaki/sdk": "workspace:*",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "jsdom": "^26.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "@vitest/coverage-v8": "^3.0.5",
    "typescript": "^5",
    "vitest": "^3.0.5"
  }
}
