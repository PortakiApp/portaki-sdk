{
  "name": "@portaki/module-cli",
  "version": "0.1.0",
  "description": "Build Portaki modules: manifest, migration bundle, backend Wasm artifact",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/PortakiApp/portaki-sdk",
    "directory": "packages/module-cli"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "bin": {
    "portaki-module": "./dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@portaki/sdk": "workspace:*",
    "jiti": "^2.4.2"
  },
  "devDependencies": {
    "typescript": "^5",
    "vitest": "^3.0.5"
  }
}
