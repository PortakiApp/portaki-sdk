{
  "$schema": "https://raw.githubusercontent.com/PortakiApp/portaki-sdk/main/schema/module.v1.json",
  "id": "checklist",
  "name": { "fr": "Checklist départ", "en": "Departure checklist" },
  "description": {
    "fr": "Items à cocher avant le départ du voyageur.",
    "en": "Items to check before guest departure."
  },
  "version": "1.0.0",
  "author": { "name": "Portaki", "url": "https://portaki.app", "type": "official" },
  "icon": "check-square",
  "type": "official",
  "tags": ["checklist", "départ"],
  "portakiVersionMin": "1.0.0",
  "license": "AGPL-3.0",
  "repository": "https://github.com/PortakiApp/portaki-sdk",
  "scopes": ["stay:read", "property:read", "checklist:write", "stay:events:write"],
  "dependencies": { "required": [], "optional": [] },
  "queries": [
    {
      "name": "checklist.items",
      "description": { "fr": "Items de la checklist du logement", "en": "Property checklist items" },
      "scope": "stay:read"
    },
    {
      "name": "checklist.completions",
      "description": { "fr": "Items cochés pour ce séjour", "en": "Checked items for this stay" },
      "scope": "stay:read"
    }
  ],
  "commands": [
    {
      "name": "checklist.complete-item",
      "description": { "fr": "Cocher un item", "en": "Check an item" },
      "scope": "checklist:write"
    },
    {
      "name": "checklist.uncomplete-item",
      "description": { "fr": "Décocher un item", "en": "Uncheck an item" },
      "scope": "checklist:write"
    }
  ],
  "events": {
    "published": [
      {
        "name": "checklist.progress-updated",
        "description": { "fr": "Progression", "en": "Progress" },
        "severity": "INFO"
      },
      {
        "name": "checklist.completed",
        "description": { "fr": "Complétée", "en": "Completed" },
        "severity": "INFO"
      }
    ],
    "subscribed": ["stay.created", "stay.deleted"]
  },
  "config": { "fields": [] },
  "slots": [
    { "name": "section", "position": "after-wifi" },
    {
      "name": "bottom-bar",
      "defaultLabel": { "fr": "Checklist", "en": "Checklist" },
      "defaultIcon": "check-square"
    }
  ],
  "screenshots": [],
  "readme": "README.md",
  "audit": {
    "events": [
      { "name": "checklist.completed", "severity": "INFO" },
      { "name": "checklist.progress-updated", "severity": "INFO" }
    ]
  },
  "catalog": {
    "tagline": { "fr": "", "en": "" },
    "npmPackage": "@portaki/module-checklist",
    "npmUrl": "https://www.npmjs.com/package/@portaki/module-checklist"
  }
}
