{
  "$schema": "../../schema/module.v1.json",
  "id": "weather",
  "name": {
    "fr": "Météo",
    "en": "Weather"
  },
  "description": {
    "fr": "Prévisions locales (Open-Meteo, sans clé API).",
    "en": "Local forecast (Open-Meteo, no API key)."
  },
  "details": {
    "fr": "Les données sont fournies par Open-Meteo (CC BY 4.0). Sans latitude/longitude dans le module, les coordonnées du logement Portaki sont utilisées si disponibles.",
    "en": "Data from Open-Meteo (CC BY 4.0). Without lat/lng in the module, Portaki property coordinates are used when available."
  },
  "examples": [
    {
      "title": { "fr": "Prévisions 3 jours", "en": "Three-day outlook" },
      "description": {
        "fr": "Sans coordonnées dans le module, les lat/lng du bien Portaki servent de point de grille.",
        "en": "Without module coordinates, Portaki property lat/lng feed the forecast grid."
      },
      "link": "https://github.com/PortakiApp/portaki-sdk/tree/develop/packages/weather"
    }
  ],
  "version": "1.0.0",
  "author": {
    "name": "Portaki",
    "url": "https://portaki.app",
    "type": "official"
  },
  "icon": "cloud-sun",
  "type": "official",
  "tags": ["weather", "forecast"],
  "portakiVersionMin": "1.0.0",
  "license": "AGPL-3.0",
  "repository": "https://github.com/PortakiApp/portaki-sdk",
  "screenshots": [],
  "config": {
    "defaults": {},
    "globalAlert": {
      "type": "info",
      "message": {
        "fr": "Données Open-Meteo (CC BY 4.0). Sans coordonnées ici, utilisation des coordonnées du bien si renseignées.",
        "en": "Open-Meteo data (CC BY 4.0). Property coordinates used when module coords are empty."
      },
      "helpUrl": "https://open-meteo.com/en/docs"
    },
    "fields": [
      {
        "key": "latitude",
        "label": { "fr": "Latitude (optionnel)", "en": "Latitude (optional)" },
        "description": {
          "fr": "Ex. 43,702 pour Mandelieu — sinon coordonnées du bien.",
          "en": "e.g. 43.702 — else property coordinates."
        },
        "type": "number",
        "required": false
      },
      {
        "key": "longitude",
        "label": { "fr": "Longitude (optionnel)", "en": "Longitude (optional)" },
        "description": {
          "fr": "Ex. 6,946 — sinon coordonnées du bien.",
          "en": "e.g. 6.946 — else property coordinates."
        },
        "type": "number",
        "required": false
      },
      {
        "key": "location_label",
        "label": { "fr": "Libellé affiché", "en": "Display label" },
        "description": {
          "fr": "Ex. « Vue mer · secteur Mandelieu ».",
          "en": "e.g. “Sea view · Mandelieu area”."
        },
        "type": "text",
        "required": false,
        "placeholder": { "fr": "Secteur météo", "en": "Forecast area" }
      },
      {
        "key": "forecast_days",
        "label": { "fr": "Jours de prévision (1–7)", "en": "Forecast days (1–7)" },
        "description": {
          "fr": "Nombre de jours affichés (max. 7).",
          "en": "Number of days shown (max 7)."
        },
        "type": "number",
        "required": false,
        "default": 3,
        "min": 1,
        "max": 7
      },
      {
        "key": "intro",
        "label": { "fr": "Texte d’intro (optionnel)", "en": "Intro text (optional)" },
        "description": {
          "fr": "Court message au-dessus des températures.",
          "en": "Short message above temperatures."
        },
        "type": "textarea",
        "required": false
      }
    ]
  },
  "catalog": {
    "tagline": {
      "fr": "Prévisions courtes pour le séjour, sans clé API.",
      "en": "Short stay forecast without an API key."
    },
    "highlights": [
      { "fr": "Open-Meteo", "en": "Open-Meteo" },
      { "fr": "Repli coordonnées du bien", "en": "Property coords fallback" }
    ],
    "npmPackage": "@portaki/module-weather",
    "npmUrl": "https://www.npmjs.com/package/@portaki/module-weather"
  }
}
